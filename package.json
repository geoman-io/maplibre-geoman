{
  "name": "@geoman-io/maplibre-geoman-workspace",
  "private": true,
  "version": "0.7.1",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "description": "Workspace and tooling for Geoman MapLibre/Mapbox packages",
  "homepage": "https://geoman.io",
  "repository": {
    "type": "git",
    "url": "git://github.com/geoman-io/maplibre-geoman.git"
  },
  "author": {
    "name": "Geoman.io",
    "email": "sales@geoman.io",
    "url": "https://geoman.io"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/geoman-io/maplibre-geoman/issues"
  },
  "scripts": {
    "turbo": "turbo",
    "build:all": "turbo run build --filter=@geoman-io/maplibre-geoman-free --filter=@geoman-io/mapbox-geoman-free",
    "typecheck:all": "turbo run ts --filter=@geoman-io/maplibre-geoman-free --filter=@geoman-io/mapbox-geoman-free",
    "lint:all": "pnpm run lint && turbo run lint",
    "workspace:validate": "node scripts/validate-workspace.mjs",
    "api:check": "node scripts/check-api-surface.mjs",
    "api:update": "node scripts/check-api-surface.mjs --write",
    "version:bump": "node scripts/bump-version.mjs",
    "dev": "pnpm run dev:maplibre",
    "dev:maplibre": "turbo run dev --filter=@geoman-io/maplibre-geoman-free",
    "dev:mapbox": "turbo run dev --filter=@geoman-io/mapbox-geoman-free",
    "ts-watch": "tsc --noEmit --watch -p tsconfig.maplibre.json",
    "ts:autofix": "ts-autofix",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "formatter": "oxfmt --check apps tests packages scripts '!packages/**/dist/**'",
    "formatter:fix": "oxfmt apps tests packages scripts '!packages/**/dist/**'",
    "check": "pnpm run formatter && pnpm run workspace:validate && pnpm run lint:all && pnpm run typecheck:all && pnpm run test:unit && pnpm run test:all",
    "clean:artifacts": "rimraf dist pub",
    "testserver": "pnpm run testserver:maplibre",
    "testserver:maplibre": "turbo run testserver --filter=@geoman-io/maplibre-geoman-free",
    "testserver:mapbox": "turbo run testserver --filter=@geoman-io/mapbox-geoman-free",
    "test": "pnpm run test:unit && pnpm run test:all",
    "test:all": "pnpm run test:maplibre && pnpm run test:mapbox",
    "test:unit": "turbo run test:unit",
    "test:maplibre": "cross-env PLAYWRIGHT_VARIANT=maplibre playwright test",
    "test:mapbox": "cross-env PLAYWRIGHT_VARIANT=mapbox playwright test",
    "test:headed": "cross-env PLAYWRIGHT_VARIANT=maplibre playwright test --headed",
    "test:ui": "cross-env PLAYWRIGHT_VARIANT=maplibre playwright test --ui",
    "test:debug": "cross-env PLAYWRIGHT_VARIANT=maplibre playwright test --debug",
    "prepare": "husky && shx test -f packages/maplibre/dist/maplibre-geoman.es.js || pnpm --filter @geoman-io/maplibre-geoman-free run build"
  },
  "dependencies": {
    "@turf/area": "^7.3.5",
    "@turf/bbox": "^7.3.5",
    "@turf/bearing": "^7.3.5",
    "@turf/boolean-intersects": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/boolean-point-on-line": "^7.3.5",
    "@turf/boolean-valid": "^7.3.5",
    "@turf/buffer": "^7.3.5",
    "@turf/centroid": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "@turf/clone": "^7.3.5",
    "@turf/combine": "^7.3.5",
    "@turf/destination": "^7.3.5",
    "@turf/difference": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/flatten": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/invariant": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/line-intersect": "^7.3.5",
    "@turf/line-split": "^7.3.5",
    "@turf/line-to-polygon": "^7.3.5",
    "@turf/meta": "^7.3.5",
    "@turf/polygon-to-line": "^7.3.5",
    "@turf/projection": "^7.3.5",
    "@turf/rewind": "^7.3.5",
    "@turf/transform-rotate": "^7.3.5",
    "@turf/transform-scale": "^7.3.5",
    "@turf/union": "^7.3.5",
    "@turf/unkink-polygon": "^7.3.5",
    "dompurify": "^3.4.2",
    "lodash-es": "^4.18.1",
    "loglevel": "^1.9.2",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.1",
    "@types/geojson": "^7946.0.16",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "mapbox-gl": "^3.23.1",
    "maplibre-gl": "^5.24.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "playwright": "1.59.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.61.1",
    "rollup-plugin-dts": "^6.4.1",
    "sass": "^1.99.0",
    "shx": "^0.4.0",
    "svelte": "^5.55.5",
    "svelte-preprocess": "^6.0.3",
    "ts-autofix": "^1.0.0",
    "tsc-alias": "^1.8.17",
    "turbo": "^2.9.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.11",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "ajv": "6.14.0"
    }
  }
}
